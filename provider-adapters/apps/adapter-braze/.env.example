# ──────────────────────────────────────────────────
# Braze Adapter — Environment Variables
# ──────────────────────────────────────────────────

NODE_ENV=development

# Braze adapter HTTP port
BRAZE_PORT=3172

# Braze REST API key (required)
BRAZE_API_KEY=

# Braze REST endpoint (required, e.g. https://rest.iad-01.braze.com)
BRAZE_REST_ENDPOINT=

# Braze application ID (required)
BRAZE_APP_ID=

# Braze webhook verification key (required)
BRAZE_WEBHOOK_KEY=

# Default "from" email address for Braze email sends (required)
BRAZE_FROM_EMAIL=

# Default "from" display name for Braze email sends (optional, default: Notifications)
BRAZE_FROM_NAME=Notifications

# Braze SMS subscription group ID (optional, required for SMS sends)
BRAZE_SMS_SUBSCRIPTION_GROUP=

# Braze WhatsApp subscription group ID (optional, required for WhatsApp sends)
BRAZE_WHATSAPP_SUBSCRIPTION_GROUP=

# Enable just-in-time user profile sync before sends (optional, default: false)
BRAZE_PROFILE_SYNC_ENABLED=false

# Profile sync LRU cache TTL in seconds (optional, default: 300)
BRAZE_PROFILE_CACHE_TTL_SECONDS=300

# HTTP request timeout in milliseconds (optional, default: 10000)
BRAZE_TIMEOUT_MS=10000

# Pepper secret for SHA-256 email hashing to generate Braze external_id (required)
EMAIL_HASH_PEPPER=

# Pepper cache TTL in seconds (optional, default: 86400)
PEPPER_CACHE_TTL=86400

# ──────────────────────────────────────────────────
# RabbitMQ (optional — adapter starts without it)
# ──────────────────────────────────────────────────

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=vhnotificationapi
RABBITMQ_USER=notificationapi
RABBITMQ_PASSWORD=
