{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/adapter-mailgun",
  "compilerOptions": {
    "webpack": false,
    "tsConfigPath": "apps/adapter-mailgun/tsconfig.app.json",
    "deleteOutDir": true
  },
  "projects": {
    "adapter-mailgun": {
      "type": "application",
      "root": "apps/adapter-mailgun",
      "entryFile": "main",
      "sourceRoot": "apps/adapter-mailgun/src",
      "compilerOptions": {
        "tsConfigPath": "apps/adapter-mailgun/tsconfig.app.json"
      }
    },
    "adapter-whatsapp": {
      "type": "application",
      "root": "apps/adapter-whatsapp",
      "entryFile": "main",
      "sourceRoot": "apps/adapter-whatsapp/src",
      "compilerOptions": {
        "tsConfigPath": "apps/adapter-whatsapp/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}
